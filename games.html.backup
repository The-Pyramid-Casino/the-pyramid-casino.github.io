                                    <i class="fas fa-star" aria-hidden="true"></i>
                                    --
                                </span>
                            </div>
                        </div>
                        <div class="game-actions">
                            <button class="btn btn-secondary" disabled>
                                <i class="fas fa-clock" aria-hidden="true"></i>
                                Coming Soon
                            </button>
                        </div>
                    </div>
                    
                    <div class="game-card" data-category="arcade">
                        <div class="game-image">
                            <i class="fas fa-puzzle-piece" aria-hidden="true"></i>
                            <div class="game-overlay">
                                <span class="game-status coming-soon">Coming Soon</span>
                            </div>
                        </div>
                        <div class="game-info">
                            <h3>Puzzle Quest</h3>
                            <p>Match-3 puzzle with betting elements</p>
                            <div class="game-meta">
                                <span class="game-category">Arcade</span>
                                <span class="game-rating">
                                    <i class="fas fa-star" aria-hidden="true"></i>
                                    --
                                </span>
                            </div>
                        </div>
                        <div class="game-actions">
                            <button class="btn btn-secondary" disabled>
                                <i class="fas fa-clock" aria-hidden="true"></i>
                                Coming Soon
                            </button>
                        </div>
                    </div>
                    
                    <div class="game-card" data-category="specialty">
                        <div class="game-image">
                            <i class="fas fa-ticket-alt" aria-hidden="true"></i>
                            <div class="game-overlay">
                                <span class="game-status available">Available</span>
                            </div>
                        </div>
                        <div class="game-info">
                            <h3>Scratch Cards</h3>
                            <p>Digital scratch-off lottery cards</p>
                            <div class="game-meta">
                                <span class="game-category">Specialty</span>
                                <span class="game-rating">
                                    <i class="fas fa-star" aria-hidden="true"></i>
                                    4.4
                                </span>
                            </div>
                        </div>
                        <div class="game-actions">
                            <a href="games/scratch.html" class="btn btn-primary">
                                <i class="fas fa-play" aria-hidden="true"></i>
                                Play Now
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="no-games-message hidden" id="noGamesMessage">
                    <div class="no-games-content">
                        <i class="fas fa-search" aria-hidden="true"></i>
                        <h3>No games found</h3>
                        <p>Try adjusting your search or filter criteria</p>
                        <button class="btn btn-secondary" id="clearFiltersBtn">
                            <i class="fas fa-times" aria-hidden="true"></i>
                            Clear Filters
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Scripts -->
    <script src="scripts/auth.js"></script>
    <script src="scripts/theme.js"></script>
    <script src="scripts/main.js"></script>
    <script src="scripts/games.js"></script>
</body>
</html>