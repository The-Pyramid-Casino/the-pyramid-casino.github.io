                        <i class="fas fa-spade" aria-hidden="true"></i>
                        Card Games
                    </button>
                    <button class="filter-btn" data-category="arcade" aria-pressed="false">
                        <i class="fas fa-gamepad" aria-hidden="true"></i>
                        Arcade
                    </button>
                    <button class="filter-btn" data-category="specialty" aria-pressed="false">
                        <i class="fas fa-star" aria-hidden="true"></i>
                        Specialty
                    </button>
                </div>
            </div>
        </section>

