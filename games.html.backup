            <div class="container">
                <div class="filters-header">
                    <h2>Find Your Game</h2>
                    <div class="search-box">
                        <div class="search-input-wrapper">
                            <i class="fas fa-search" aria-hidden="true"></i>
                            <input 
                                type="text" 
                                id="gameSearch" 
                                placeholder="Search games..." 
                                aria-label="Search games"
                                autocomplete="off"
                            >
                        </div>
                    </div>
                </div>
                
                <div class="filter-buttons">
                    <button class="filter-btn active" data-category="all" aria-pressed="true">
                        <i class="fas fa-th" aria-hidden="true"></i>
                        All Games
                    </button>
                    <button class="filter-btn" data-category="slots" aria-pressed="false">
                        <i class="fas fa-coins" aria-hidden="true"></i>
                        Slots
                    </button>
                    <button class="filter-btn" data-category="table" aria-pressed="false">
                        <i class="fas fa-chess-board" aria-hidden="true"></i>
                        Table Games
                    </button>
